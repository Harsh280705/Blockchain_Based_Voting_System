<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Profile</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        body {
            background: linear-gradient(to bottom, #000 0%, #333 100%); /* Black to dark gray gradient */
            font-family: "SUSE", sans-serif;
            color: white;
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .container {
            width: 90%;
            max-width: 800px;
            margin: 20px auto;
            background-color: #222;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.5);
        }

        h1 {
            text-align: center;
            color: #fff;
            margin-bottom: 30px;
        }

        .profile-details {
            display: flex;
            flex-direction: column;
        }

        .profile-details div {
            margin-bottom: 15px;
        }

        .profile-details label {
            font-weight: bold;
            color: #ccc;
        }

        .profile-details span {
            color: #fff;
            font-size: 18px;
        }

        /* Specific styling for the voter ID */
        .voter-id {
            color: #fff; /* Ensures the voter ID text is white */
        }

        .back-button {
            display: inline-block;
            margin-top: 20px;
            padding: 10px 20px;
            background-color: #555;
            color: white;
            text-decoration: none;
            border-radius: 5px;
            transition: background 0.3s ease;
        }

        .back-button:hover {
            background-color: #777;
        }

        .forgot-password {
            display: block;
            margin-top: 10px;
            color: #ccc; /* Color for the forgot password link */
            text-align: center;
            text-decoration: none;
            font-size: 14px;
            text-transform: uppercase; /* Make text uppercase */
        }

        .forgot-password:hover {
            color: #fff; /* Change color on hover */
        }

        footer {
            text-align: center;
            padding: 10px;
            background: #333;
            color: #fff;
            width: 100%;
            position: relative;
            margin-top: auto;
        }
        
        /* Optional styling for the profile image */
        .profile-image {
            display: block;
            margin: 20px auto;
            border-radius: 50%; /* Makes the image round */
            width: 150px; /* Set the width of the image */
            height: 150px; /* Set the height of the image */
            object-fit: cover; /* Ensures the image covers the area without distortion */
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>Your Profile</h1>

        <!-- Optional profile image insertion -->
        <img src="/path/to/your/image.jpg" alt="Profile Image" class="profile-image"> <!-- Change the src to the actual image path -->

        <div class="profile-details">
            <div>
                <label>Username:</label>
                <span><%= user.username %></span>
            </div>

            <div>
                <label>Email:</label>
                <span><%= user.email %></span>
            </div>

            <div>
                <label>Voter ID:</label>
                <span class="voter-id"><%= user.voter_id %></span> <!-- Voter ID styling applied here -->
            </div>

            <!-- You can add more profile details here if needed -->
        </div>

        <a href="/dashboard" class="back-button">Back to Dashboard</a>
        
        <!-- Forgot Password link -->
        <a href="/forgot-password" class="forgot-password">FORGOT YOUR PASSWORD?</a> <!-- Link for password recovery -->
    </div>

    <footer>
        <p>&copy; 2024 MyVotingSite.com</p>
    </footer>
</body>
</html>
