<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Voter Registration</title>
    <style>
        body {
            font-family: 'Helvetica', sans-serif;
            background-color: #f0f0f5;
            margin: 0;
            padding: 0;
        }

        .container {
            width: 500px;
            margin: 50px auto;
            padding: 30px;
            background-color: #ffffff;
            box-shadow: 0 0 15px rgba(0, 0, 0, 0.2);
            border-radius: 10px;
        }

        h1 {
            text-align: center;
            color: #333;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            color: #444;
            font-weight: 500;
        }

        input[type="text"],
        input[type="email"],
        input[type="password"],
        input[type="file"] {
            width: 100%;
            padding: 12px;
            border: 1px solid #ccc;
            border-radius: 6px;
            font-size: 15px;
        }

        button {
            width: 100%;
            padding: 12px;
            background-color: #007bff;
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 18px;
            margin-top: 20px;
        }

        button:hover {
            background-color: #0056b3;
        }

        .step {
            display: none;
        }

        .step.active {
            display: block;
        }

        .progress {
            display: flex;
            justify-content: space-between;
            margin-bottom: 20px;
        }

        .progress-bar {
            width: 30%;
            height: 10px;
            background-color: #ccc;
            border-radius: 5px;
            overflow: hidden;
        }

        .progress-bar div {
            height: 100%;
            background-color: #007bff;
            width: 0%;
        }

        .error {
            color: red;
            text-align: center;
            margin-top: 10px;
        }

        .navigation-buttons {
            display: flex;
            justify-content: space-between;
        }

    </style>
</head>

<body>
    <div class="container">
        <h1>Voter Registration</h1>
        
        <!-- Progress Bar -->
        <div class="progress">
            <div class="progress-bar"><div></div></div>
            <div class="progress-bar"><div></div></div>
            <div class="progress-bar"><div></div></div>
        </div>

        <!-- Step 1: Name Details -->
        <form id="registrationForm" action="/register" method="POST" enctype="multipart/form-data">
            <div class="step active" id="step1">
                <div class="form-group">
                    <label for="firstName">First Name</label>
                    <input type="text" id="firstName" name="firstName" required>
                </div>
                <div class="form-group">
                    <label for="middleName">Middle Name</label>
                    <input type="text" id="middleName" name="middleName" required>
                </div>
                <div class="form-group">
                    <label for="lastName">Last Name</label>
                    <input type="text" id="lastName" name="lastName" required>
                </div>
                <div class="form-group">
                    <label for="motherName">Mother's Name</label>
                    <input type="text" id="motherName" name="motherName" required>
                </div>
                <div class="navigation-buttons">
                    <div></div>
                    <button type="button" onclick="nextStep()">Next</button>
                </div>
            </div>

            <!-- Step 2: Document Upload -->
            <div class="step" id="step2">
                <div class="form-group">
                    <label for="document">Upload Document (Aadhaar, Passport, etc.)</label>
                    <input type="file" id="document" name="document" accept=".pdf,.jpg,.jpeg,.png" required>
                </div>
                <div class="navigation-buttons">
                    <button type="button" onclick="prevStep()">Previous</button>
                    <button type="button" onclick="nextStep()">Next</button>
                </div>
            </div>

            <!-- Step 3: Additional Information -->
            <div class="step" id="step3">
                <div class="form-group">
                    <label for="email">Email Address</label>
                    <input type="email" id="email" name="email" required>
                </div>
                <div class="form-group">
                    <label for="address">Address</label>
                    <input type="text" id="address" name="address" required>
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" required>
                </div>
                <div class="form-group">
                    <label for="confirmPassword">Confirm Password</label>
                    <input type="password" id="confirmPassword" name="confirmPassword" required>
                </div>
                <div class="navigation-buttons">
                    <button type="button" onclick="prevStep()">Previous</button>
                    <button type="submit">Register</button>
                </div>
            </div>
        </form>

        <% if (typeof errorMessage !== 'undefined') { %>
            <p class="error"><%= errorMessage %></p>
        <% } %>
    </div>

    <script>
        let currentStep = 0;
        const steps = document.querySelectorAll('.step');
        const progressBars = document.querySelectorAll('.progress-bar div');

        // Move to the next step
        function nextStep() {
            const currentFormGroup = steps[currentStep].querySelectorAll('input');
            let allValid = true;

            currentFormGroup.forEach(input => {
                if (!input.checkValidity()) {
                    allValid = false;
                    input.reportValidity(); // Show validation message
                }
            });

            if (allValid) {
                steps[currentStep].classList.remove('active');
                currentStep++;
                if (currentStep < steps.length) {
                    steps[currentStep].classList.add('active');
                    updateProgress();
                }
            }
        }

        // Move to the previous step
        function prevStep() {
            steps[currentStep].classList.remove('active');
            currentStep--;
            if (currentStep >= 0) {
                steps[currentStep].classList.add('active');
                updateProgress();
            }
        }

        function updateProgress() {
            progressBars.forEach((bar, index) => {
                bar.style.width = index <= currentStep ? '100%' : '0%';
            });
        }
    </script>
</body>
</html>
